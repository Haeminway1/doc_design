{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestAnalysisContent",
  "description": "AI가 생성해야 하는 시험 분석 콘텐츠 JSON 스키마. 채점 데이터는 시스템이 제공하며, AI는 분석/해석/솔루션만 생성.",
  "type": "object",
  "required": ["studentName", "examName", "overallComment", "sectionAnalyses", "solutions", "encouragement"],
  "properties": {
    "studentName": {
      "type": "string",
      "description": "학생 이름"
    },
    "examName": {
      "type": "string",
      "description": "시험 이름",
      "examples": ["2026 대비 레벨테스트", "중간고사 영어", "모의고사 3회"]
    },
    "overallComment": {
      "type": "string",
      "description": "종합 소견. 전체 성적에 대한 분석적 코멘트. 2~4문장."
    },
    "sectionAnalyses": {
      "type": "array",
      "description": "영역별 분석. 시험의 각 섹션(어법/어휘/독해 등)에 대한 심층 분석. 시험 유형에 따라 섹션이 다를 수 있음.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sectionName", "overview", "wrongItems", "studyPoints"],
        "properties": {
          "sectionName": {
            "type": "string",
            "description": "영역명",
            "examples": ["어법", "어휘", "장문독해", "문법", "리스닝"]
          },
          "overview": {
            "type": "string",
            "description": "해당 영역에 대한 분석 개요. 2~3문장."
          },
          "wrongItems": {
            "type": "array",
            "description": "오답 문항 분석. 해당 영역에서 틀린 문항에 대한 개별 해설.",
            "items": {
              "type": "object",
              "required": ["number", "correct", "student", "explanation"],
              "properties": {
                "number": {
                  "type": "integer",
                  "description": "문항 번호"
                },
                "correct": {
                  "type": "string",
                  "description": "정답",
                  "examples": ["A", "B", "C", "D"]
                },
                "student": {
                  "type": "string",
                  "description": "학생 답안"
                },
                "explanation": {
                  "type": "string",
                  "description": "오답 원인 분석 및 해설. 왜 틀렸는지, 정답이 왜 맞는지 설명."
                }
              }
            }
          },
          "studyPoints": {
            "type": "array",
            "description": "해당 영역 학습 포인트. 구체적인 학습 방향 제시.",
            "minItems": 2,
            "maxItems": 5,
            "items": { "type": "string" }
          }
        }
      }
    },
    "solutions": {
      "type": "array",
      "description": "우선순위별 종합 솔루션. 가장 시급한 것부터 정렬.",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["title", "items"],
        "properties": {
          "title": {
            "type": "string",
            "description": "솔루션 제목",
            "examples": ["어법 기본기 재정립", "어휘력 폭발적 확장"]
          },
          "items": {
            "type": "array",
            "description": "구체적 실행 항목",
            "minItems": 2,
            "maxItems": 5,
            "items": { "type": "string" }
          }
        }
      }
    },
    "encouragement": {
      "type": "string",
      "description": "격려 메시지. <span class=\"emphasis\">강조</span> 마크업 사용 가능. 학생에게 동기부여가 되는 메시지."
    }
  }
}
