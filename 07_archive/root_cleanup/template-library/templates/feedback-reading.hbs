<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{student.name}} 독해 피드백지 · {{student.date}}</title>
  <style>{{{css}}}</style>
</head>
<body>

{{!-- 리포트 헤더 + 학습 요약 --}}
{{> header}}

{{!-- Section 1: 틀린 문제 리스트 --}}
<div class="section-header page-break-before">
  <span class="section-num">Section 1</span>
  문제 리스트
</div>

{{#each problems}}
{{> problem-card}}
{{/each}}

{{!-- Section 2: 해설 파트 (지문별 5단계 분석) --}}
<div class="section-header page-break-before">
  <span class="section-num">Section 2</span>
  지문별 해설
</div>

{{#each themes}}
{{#if (eq category "reading")}}
<div class="avoid-break" style="margin-bottom: 6px;">
  <h2>{{id}}. {{title}}</h2>
  <p style="font-size: 9pt; color: #718096; margin-bottom: 12px;">
    관련 문제:
    {{#each problemNums}}
    <span style="display: inline-block; background-color: #EDF5FC; border: 1px solid #B8D4EC; border-radius: 10px; padding: 1px 8px; margin: 1px; font-size: 8pt; color: #4A90C4; font-weight: 700;">{{this}}</span>
    {{/each}}
  </p>
</div>

{{!-- 5단계 독해 분석 --}}
{{> reading-passage}}

{{!-- 오답 분석 (학생 답 분석) --}}
{{#if wrongAnalysis.length}}
<h4 style="color: #c05621; margin-top: 16px;">오답 분석</h4>
{{> wrong-analysis}}
{{/if}}

<hr class="section-divider">
{{/if}}
{{/each}}

{{!-- 종합 분석 --}}
<div class="section-header page-break-before">
  <span class="section-num">Section 3</span>
  종합 분석
</div>

{{> summary}}

{{!-- 독해는 연습문제 없음 --}}

{{!-- 푸터 --}}
{{> footer}}

</body>
</html>
