{{#each wrongAnalysis}}
<div class="avoid-break" style="margin: 12px 0; border-left: 3px solid #B8D4EC; padding-left: 12px;">
  <p style="font-weight: 700; color: #2d3748; margin-bottom: 4px;">문제 {{problemNum}} 오답 분석</p>
  {{#if description}}
  <p style="margin-bottom: 6px;">{{description}}</p>
  {{/if}}
  {{#if analysis}}
  <div class="concept-box" style="margin-bottom: 8px;">
    <span class="concept-label">해설 포인트</span>
    <p>{{{analysis}}}</p>
  </div>
  {{/if}}
  {{#if studentAnalysis}}
  <div class="tip-box avoid-break">
    <span class="tip-label">학생 답 분석</span>
    <table style="margin: 6px 0 0 0; font-size: 9pt;">
      <tbody>
        <tr>
          <td style="font-weight: 700; white-space: nowrap; width: 140px; color: #c05621; border: none; padding: 4px 8px 4px 0;">왜 이 답을 골랐을까</td>
          <td style="border: none; padding: 4px 0;">{{studentAnalysis.whyChosen}}</td>
        </tr>
        <tr>
          <td style="font-weight: 700; white-space: nowrap; color: #c05621; border: none; padding: 4px 8px 4px 0;">오류 패턴</td>
          <td style="border: none; padding: 4px 0;">{{studentAnalysis.errorPattern}}</td>
        </tr>
        <tr>
          <td style="font-weight: 700; white-space: nowrap; color: #c05621; border: none; padding: 4px 8px 4px 0;">집중 포인트</td>
          <td style="border: none; padding: 4px 0;">{{studentAnalysis.focusPoint}}</td>
        </tr>
      </tbody>
    </table>
  </div>
  {{/if}}
</div>
{{/each}}
